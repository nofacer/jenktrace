{
	"name": "jenktrace",
	"version": "1.0.5",
	"description": "jenktrace desktop app",
	"scripts": {
		"prepare": "husky",
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build",
		"build:canary": "vite build && electrobun build --env=canary && bun scripts/keep-only-dmg.mjs",
		"build:stable": "vite build && electrobun build --env=stable && bun scripts/keep-only-dmg.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "bun run lint && bunx --bun tsc --noEmit && bun run build",
		"predev": "bun run build"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@fontsource-variable/geist": "^5.2.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.18.1",
		"lucide-react": "^1.17.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"recharts": "3.8.0",
		"shadcn": "^4.8.2",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/vite": "^4.1.8",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"tailwindcss": "^4.1.8",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
